{
    "name": "tuktuk-scg-scrapper",
    "version": "0.3.0",
    "description": "The starcitygames.com shop price srapper.",
    "homepage": "https://scg.dekker.lol",
    "email": "dekker25@gmail.com",
    "engines": {
        "node": ">=22.12"
    },
    "scripts": {
        "build": "npm run build --workspaces --if-present",
        "dev": "concurrently -n proxy,server,storage,frontend -c blue,green,yellow,magenta \"npm:dev -w @tuktuk-scg-scrapper/proxy\" \"npm:dev -w @tuktuk-scg-scrapper/server\" \"npm:dev -w @tuktuk-scg-scrapper/storage\" \"npm:dev -w @tuktuk-scg-scrapper/frontend\"",
        "test": "vitest run",
        "test:ci": "vitest run --reporter=default",
        "typecheck:tools": "tsc -p tsconfig.tools.json",
        "update-index": "node --max_old_space_size=8192 -r ts-node/register ./update-index.ts",
        "upsert-database": "cross-env MONGO_INITDB_ROOT_USERNAME=$MONGO_USER MONGO_INITDB_ROOT_PASSWORD=$MONGO_PWORD node --max_old_space_size=8192 -r ts-node/register ./tools/updater/upsert.ts",
        "docker:build": "docker-compose build && node ./tools/tag.js",
        "build:function": "esbuild tools/generator/scryfall/cloud.ts --bundle --platform=node --target=node22 --outfile=build/function/index.js --minify --sourcemap",
        "prepare": "husky || true"
    },
    "repository": "https://github.com/Dekkee/tuktuk-scg-scrapper.git",
    "main": "index.js",
    "author": "Dekker",
    "license": "MIT",
    "private": true,
    "dependencies": {
        "@types/body-parser": "1.19.6",
        "@types/compression": "1.8.1",
        "@types/cors": "2.8.19",
        "@types/express": "5.0.6",
        "@types/morgan": "1.9.10",
        "axios": "1.17.0",
        "body-parser": "2.2.2",
        "colors": "1.4.0",
        "compression": "1.8.1",
        "cors": "2.8.6",
        "express": "5.2.1",
        "is-docker": "2.2.1",
        "morgan": "1.11.0",
        "pretty-bytes": "5.6.0",
        "progress": "2.0.3"
    },
    "devDependencies": {
        "@aws-sdk/client-s3": "3.1067.0",
        "@aws-sdk/lib-storage": "3.1067.0",
        "@types/node": "25.9.3",
        "async": "3.2.6",
        "concurrently": "10.0.3",
        "cross-env": "10.1.0",
        "esbuild": "0.28.1",
        "flexsearch": "0.7.21",
        "husky": "9.1.7",
        "lint-staged": "17.0.7",
        "nodemon": "3.1.14",
        "prettier": "3.8.4",
        "stream-chain": "4.2.5",
        "stream-json": "3.4.0",
        "ts-node": "10.9.2",
        "typescript": "6.0.3",
        "vitest": "4.1.8",
        "yargs": "17.7.2"
    },
    "workspaces": [
        "packages/*"
    ],
    "overrides": {
        "ajv": "8.20.0"
    },
    "lint-staged": {
        "*.{ts,tsx,js,css,json,md}": [
            "prettier --write"
        ]
    }
}
