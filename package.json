{
    "name": "tuktuk-scg-scrapper",
    "version": "0.3.0",
    "description": "The starcitygames.com shop price srapper.",
    "homepage": "https://scg.dekker.gdn",
    "email": "dekker25@gmail.com",
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "build": "npm run build --workspaces --if-present",
        "dev": "npm run dev --workspaces --if-present",
        "test": "npm run test --workspaces --if-present",
        "test:ci": "npm run test:ci --workspaces --if-present",
        "update-index": "node --max_old_space_size=8192 -r ts-node/register ./update-index.ts",
        "upsert-database": "cross-env MONGO_INITDB_ROOT_USERNAME=$MONGO_USER MONGO_INITDB_ROOT_PASSWORD=$MONGO_PWORD node --max_old_space_size=8192 -r ts-node/register ./tools/updater/upsert.ts",
        "docker:build": "docker-compose build && node ./tools/tag.js",
        "build:function": "esbuild tools/generator/scryfall/cloud.ts --bundle --platform=node --target=node22 --outfile=build/function/index.js --minify --sourcemap",
        "prepare": "husky"
    },
    "repository": "https://github.com/Dekkee/tuktuk-scg-scrapper.git",
    "main": "index.js",
    "author": "Dekker",
    "license": "MIT",
    "private": true,
    "dependencies": {
        "@babel/cli": "^7.8.4",
        "@types/body-parser": "^1.17.0",
        "@types/cors": "^2.8.4",
        "@types/express": "^4.16.0",
        "@types/morgan": "^1.7.35",
        "axios": "^1.7.7",
        "body-parser": "^1.18.3",
        "colors": "^1.3.1",
        "compression": "^1.7.4",
        "cors": "^2.8.4",
        "express": "^4.16.3",
        "is-docker": "^2.0.0",
        "morgan": "^1.9.0",
        "pretty-bytes": "^5.3.0",
        "progress": "^2.0.3",
        "ts-node": "^10.9.1"
    },
    "devDependencies": {
        "@babel/core": "^7.9.6",
        "@babel/preset-env": "^7.9.6",
        "@babel/preset-typescript": "^7.9.0",
        "@types/jest": "^29.2.4",
        "@types/mongoose": "^5.7.13",
        "@types/node": "^22",
        "async": "^3.2.0",
        "aws-sdk": "^2.1282.0",
        "babel-jest": "^29.3.1",
        "cross-env": "^7.0.2",
        "esbuild": "^0.20.0",
        "husky": "^9.1.7",
        "jest": "^26.2.1",
        "lint-staged": "^15.2.10",
        "nodemon": "^2.0.3",
        "prettier": "^3.3.3",
        "stream-chain": "^2.2.1",
        "stream-json": "^1.3.3",
        "typescript": "^4.1.0",
        "yargs": "^17.5.1"
    },
    "workspaces": [
        "packages/*"
    ],
    "overrides": {
        "ajv": "^8.0.0",
        "bson": "~4.7.0"
    },
    "lint-staged": {
        "!(*generated|*data)/*.{ts,js,css,json,md}": [
            "prettier --write"
        ]
    }
}
