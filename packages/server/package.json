{
    "name": "@tuktuk-scg-scrapper/server",
    "version": "0.1.1",
    "scripts": {
        "start": "ts-node ./server.ts",
        "build": "tsc -b",
        "dev": "nodemon",
        "test": "vitest run",
        "test:ci": "vitest run --reporter=default"
    },
    "dependencies": {
        "@tuktuk-scg-scrapper/common": "0.0.1",
        "@types/async": "3.2.25",
        "@types/lodash": "4.17.24",
        "async": "3.2.6",
        "cheerio": "1.2.0",
        "flexsearch": "0.7.21",
        "lodash": "4.18.1",
        "prom-client": "15.1.3"
    },
    "nodemonConfig": {
        "watch": [
            "."
        ],
        "ext": "ts",
        "ignore": [
            "./**/*.spec.ts"
        ],
        "exec": "ts-node ./server.ts"
    }
}
